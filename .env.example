### Core Supabase client (used by the React app)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

### Backend / automation (not used in this Vite client yet, but useful for scripts/webhooks)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_JWT_SECRET=your-jwt-secret

### Optional: Auth + email settings (for magic links, transactional emails, etc.)
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password

### Optional: Payment providers (for India)
# RAZORPAY_KEY_ID=rzp_test_xxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxx
# CASHFREE_APP_ID=CFxxxxxxxx
# CASHFREE_SECRET_KEY=xxxxxxxx

### Optional: Webhook verification secrets
# RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
# CASHFREE_WEBHOOK_SECRET=your-cashfree-webhook-secret
